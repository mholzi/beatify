# ===========================================
# Beatify — HACS-ready repo
# Only keep files required for HACS install:
#   custom_components/beatify/  hacs.json
#   README.md  LICENSE  images/
# ===========================================

# ---- Dev / build frameworks ----
_bmad/
_bmad-output/
.agentforce/
.claude/
scripts/
docs/
.playwright-mcp/

# ---- Duplicate deployed copy ----
beatify/

# ---- Secrets ----
.env
*.env.local

# ---- Config & tooling ----
pyproject.toml
package-lock.json
requirements.txt
# requirements_test.txt intentionally NOT ignored
.ruff.toml

# ---- Tests ----
# tests/ intentionally NOT ignored — test suite is part of the repo
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# ---- Node ----
node_modules/

# ---- Python artifacts ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/

# ---- Linting ----
.ruff_cache/
.mypy_cache/

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Misc ----
config/*
!config/configuration.yaml
community-post.md
*.bak
INFLUENCER_OUTREACH.md
beatify-stats.md
beatify-stats-history.json

# ---- Release notes (keep CHANGELOG.md) ----
RELEASE_NOTES_*.md
CONTRIBUTING.md

# ---- GitHub workflows (not needed in HACS release) ----
# .github/ is kept — needed for CI and HACS validation

# ---- Minified build artefacts (auto-generated, not tracked) ----
# Run `make build` locally or see .github/workflows/build-assets.yml
custom_components/beatify/www/**/*.min.js
custom_components/beatify/www/**/*.min.css
scripts/.env
